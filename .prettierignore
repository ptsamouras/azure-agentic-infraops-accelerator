# Paths Prettier should ignore. Keep in sync with eslint.config.mjs ignores.
node_modules/
# Adopt-narrow: site/ is deferred for eslint AND prettier (90-day reassessment).
# It also contains *.astro files that require prettier-plugin-astro (not installed),
# so formatting site/ would hard-error. Mirror the eslint ignore here.
site/
agent-output/
tmp/
infra/
logs/
assets/
**/*.min.js

# Deno-managed: uses deno fmt
tools/mcp-servers/drawio/

# Caches
.eslintcache
node_modules/.cache/

# CI scan artifacts (e.g. gitleaks/CodeQL write results.sarif into the workspace
# before later steps run; Prettier must not try to format tool output).
*.sarif

# Build artefacts
*.tsbuildinfo

# AI-author markdown — Prettier's markdown printer collapses mixed-marker
# numbered lists (6a. / 7. / 8. / 9a.) with 4-space sub-paragraph
# continuations, which breaks agent definitions and instruction files.
# Linting is handled by markdownlint-cli2; line length by MD013 (120 chars).
# Run `npx prettier --check '.github/agents/**/*.md'` to verify the
# disagreement is intentional before removing these globs.
.github/agents/
.github/instructions/
.github/skills/
tools/apex-prompts/
AGENTS.md

# Root + repo markdown is owned by markdownlint-cli2, not Prettier (consistent
# with AGENTS.md above). Keep Prettier off these so `format:check .` is clean.
README.md
CHANGELOG.md
CONTRIBUTING.md
CONTRIBUTORS.md
QUALITY_SCORE.md
VERSION.md

# Generated JSON — owned by their generators; Prettier must not fight them.
# (model-catalog.json ← generate-model-catalog.mjs; azure-deprecations.json is
# a fetched data snapshot; mcp.json is hand-maintained with a fixed shape.)
.github/model-catalog.json
.github/data/azure-deprecations.json
.vscode/mcp.json

# Generated caches / rendered summaries — owned by their generators.
tools/scripts/_data/
tools/scripts/_lib/artifact-headings-summary.json

# Expected-output test fixtures (reformatting would break replay assertions).
tests/fixtures/

# Repo markdown docs are markdownlint-owned (proseWrap=preserve still reflows
# tables); keep Prettier off long-form docs with hand-aligned tables.
tools/apex-recall/docs/decision-keys.md
